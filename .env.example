# LLM — provider-agnostic, OpenAI-compatible (NFR-007b). Set ONE provider key;
# the provider is auto-detected (Gemini preferred), or force it with LLM_PROVIDER.
# Absent key ⇒ LLM features disabled (deterministic fallback, no repair).
#
# Google Gemini (free tier via AI Studio):
GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-3.5-flash            # optional override
#
# NVIDIA NIM (original provider, 2026-06-05):
# NVIDIA_API_KEY=your_key_here
# NIM_MODEL=meta/llama-3.3-70b-instruct    # optional override
#
# LLM_PROVIDER=gemini                       # force provider: gemini | nim
# LLM_DISABLED=true                         # force deterministic descriptions

# Tool-description proposal batching (P2-6, NFR-007b).
# PROPOSAL_BATCH_SIZE=5                      # tools described per LLM call (1-20)
# PROPOSAL_CONCURRENCY=3                     # batches in flight at once (1-10)

# Repair loop (P4-5/6, FR-026). Bounded self-repair of failing tests; runs on
# the job queue only when the LLM is configured. Each pass ≈ LLM (~40s) + sandbox.
# MAX_REPAIR_ATTEMPTS=2
# REPAIR_MAX_TOKENS=4096

# Database (Phase 1)
DATABASE_URL=postgresql://unumcp:unumcp@localhost:5433/unumcp

# Redis / background job queue (P6-6, NFR-006).
# With no REDIS_URL the platform runs jobs INLINE (no broker needed for dev).
# Set REDIS_URL to enable the durable BullMQ queue; JOBS_INLINE=true forces inline.
REDIS_URL=redis://localhost:6379
# JOBS_INLINE=true
